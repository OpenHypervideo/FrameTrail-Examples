            "frametrail:resourceId": "42",
            "frametrail:attributes": {
                "extract": "Normalizácia je v dejinách Česko-Slovenskav širšom zmysle historické obdobie od augusta 1968 do konca roka 1989,\nv užšom zmysle len likvidácia výsledkov Pražskej jari zakotvená v tzv. moskovskom protokole z augusta 1968 a vykonaná do 14. zjazdu KSČ v máji 1971.",
                "extract_html": "<p><b>Normalizácia</b> je v dejinách Česko-Slovenska</p><ul><li>v širšom zmysle historické obdobie od augusta 1968 do konca roka 1989,</li>\n<li>v užšom zmysle len likvidácia výsledkov Pražskej jari zakotvená v tzv. moskovskom protokole z augusta 1968 a vykonaná do 14. zjazdu KSČ v máji 1971.</li></ul>",
                "description": "",
                "articleUrl": "https://sk.wikipedia.org/wiki/Normaliz%C3%A1cia_(%C4%8CSSR)",
