                    "onClickContentItem": "",
                    "html": "<style>\n  .bio-stepper *, .bio-stepper *::before, .bio-stepper *::after {\n    box-sizing: border-box;\n    margin: 0;\n    padding: 0;\n  }\n\n  .bio-stepper {\n    --c: 22, 38, 58;       /* main RGB color \u2014 tweak this one value */\n    --dot-size: 16px;\n    width: 100%;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 28px 16px;\n    box-sizing: border-box;\n  }\n\n  .bio-stepper__steps-wrap {\n    flex: 1;\n    width: 100%;\n    max-width: 220px;\n    position: relative;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n  }\n\n  .bio-stepper__track {\n    position: absolute;\n    left: calc(var(--dot-size) / 2);\n    top:    calc(var(--dot-size));\n    bottom: calc(var(--dot-size));\n    width: 2px;\n    transform: translateX(-50%);\n    background: rgba(var(--c), 0.08);\n    border-radius: 2px;\n    overflow: hidden;\n  }\n\n  .bio-stepper__track-fill {\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 0%;\n    background: rgba(var(--c), 0.5);\n    border-radius: 2px;\n    transition: height 0.55s cubic-bezier(0.65, 0, 0.35, 1);\n  }\n\n  .bio-stepper__step {\n    border: none !important;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    cursor: pointer;\n    position: relative;\n    z-index: 1;\n    padding: 3px 0;\n    user-select: none;\n    -webkit-tap-highlight-color: transparent;\n  }\n\n  .bio-stepper__dot {\n    width:  var(--dot-size);\n    height: var(--dot-size);\n    border-radius: 50%;\n    border: 1.5px solid rgba(var(--c), 0.15);\n    background: transparent;\n    flex-shrink: 0;\n    transition: border-color 0.3s, background 0.3s, transform 0.25s;\n  }\n\n  .bio-stepper__step-name  { opacity: 0.2; transition: opacity 0.3s; font-size: 1em; text-transform: uppercase; line-height: 0.8em; }\n  .bio-stepper__step-scale { opacity: 0.1; transition: opacity 0.3s; font-size: 0.9em; }\n\n  /* hover */\n  .bio-stepper__step:hover .bio-stepper__dot      { border-color: rgba(var(--c), 0.4); }\n  .bio-stepper__step:hover .bio-stepper__step-name { opacity: 0.4; }\n\n  /* done */\n  .bio-stepper__step.is-done .bio-stepper__dot      { background: rgba(var(--c), 0.35); border-color: transparent; }\n  .bio-stepper__step.is-done .bio-stepper__step-name { opacity: 0.35; }\n\n  /* active */\n  .bio-stepper__step.active .bio-stepper__dot {\n    background: rgba(var(--c), 1);\n    border-color: transparent;\n    transform: scale(1.25);\n    box-shadow: 0 0 8px rgba(var(--c), 0.5);\n  }\n  .bio-stepper__step.active .bio-stepper__step-name  { opacity: 1; color: rgba(var(--c), 1); }\n  .bio-stepper__step.active .bio-stepper__step-scale { opacity: 0.6; }\n</style>\n\n<div class=\"bio-stepper\">\n  <div class=\"bio-stepper__steps-wrap\" id=\"bioStepperWrap\">\n    <div class=\"bio-stepper__track\">\n      <div class=\"bio-stepper__track-fill\" id=\"bioStepperFill\"></div>\n    </div>\n  </div>\n</div>",
