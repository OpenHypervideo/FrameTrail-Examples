    "globalEvents": {
        "onReady": "window.STEPS = [\n  { \n    seconds: 4,\n    name: 'Organism',\n    scale: 'metres'\n  },\n  {\n    seconds: 8,\n    name: 'Organ Systems',\n    scale: 'millimetres'\n  },\n  {\n    seconds: 17,\n    name: 'Organs',\n    scale: 'millimetres'\n  },\n  {\n    seconds: 28,\n    name: 'Tissues',\n    scale: 'millimetres'\n  },\n  {\n    seconds: 35,\n    name: 'Cells',\n    scale: 'micrometres'\n  },\n  {\n    seconds: 50,\n    name: 'Organelles',\n    scale: 'micrometres'\n  },\n  {\n    seconds: 69,\n    name: 'Chromosomes',\n    scale: 'micrometres'\n  },\n  {\n    seconds: 85,\n    name: 'DNA',\n    scale: 'nanometres'\n  }\n]; \n\nconst REVERSE_STEPS = [\n  { seconds: 146, step: 7 },\n  { seconds: 149, step: 6 },\n  { seconds: 153, step: 5 },\n  { seconds: 155, step: 4 },\n  { seconds: 157, step: 3 },\n  { seconds: 158.5, step: 2 },\n  { seconds: 161, step: 1 }\n];\n\nconst wrap   = document.getElementById('bioStepperWrap');\nconst fillEl = document.getElementById('bioStepperFill');\n\nSTEPS.forEach((s, i) => {\n  const el = document.createElement('div');\n  el.className = 'bio-stepper__step timebased';\n  el.dataset.start = (i === 0) ? 0 : s.seconds;\n  el.dataset.end   = (STEPS[i + 1]?.seconds ?? 172) - 1;\n  el.innerHTML = `\n    <div class=\"bio-stepper__dot\"></div>\n    <div>\n      <div class=\"bio-stepper__step-name\">${s.name}</div>\n      <div class=\"bio-stepper__step-scale\">${s.scale}</div>\n    </div>`;\n  el.addEventListener('click', function() { \n    myInstance.currentTime = STEPS[i].seconds;\n    goToStep(i + 1);\n  });\n  wrap.appendChild(el);\n});\n\nfunction updateUI(n) {\n  wrap.querySelectorAll('.bio-stepper__step').forEach((el, i) => {\n    el.classList.toggle('is-done',   i + 1 < n);\n    el.classList.toggle('active', i + 1 === n);\n  });\n  fillEl.style.height = ((n - 1) / (STEPS.length - 1) * 100) + '%';\n}\n\nwindow.goToStep = function (n) {\n  updateUI(Math.max(1, Math.min(STEPS.length, Math.round(n))));\n};\n\ngoToStep(1);\n\nmyInstance.addEventListener('timeupdate', function() {\n  const t = myInstance.currentTime;\n\n  // Check reverse overrides first (check from last to first so highest time wins)\n  for (let i = REVERSE_STEPS.length - 1; i >= 0; i--) {\n    if (t >= REVERSE_STEPS[i].seconds) {\n      goToStep(REVERSE_STEPS[i].step);\n      return; // skip normal logic\n    }\n  }\n\n  // Normal forward logic\n  let active = 0;\n  for (let i = 0; i < window.STEPS.length; i++) {\n    if (t >= window.STEPS[i].seconds) active = i;\n    else break;\n  }\n  goToStep(active + 1);\n});",
        "onPlay": "",
        "onPause": "",
        "onEnded": ""
    },
